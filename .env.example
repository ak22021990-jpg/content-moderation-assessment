# HMAC shared secret for client-to-server payload signing.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_HMAC_SECRET=generate_with_node_-e_console.log_crypto.randomBytes_32_toString_hex

# Google Apps Script doPost webhook endpoint URL
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Submission backend toggle: "apps-script" (default) or "formspree"
VITE_SUBMISSION_BACKEND=apps-script

# Formspree form ID (only used when VITE_SUBMISSION_BACKEND=formspree)
VITE_FORMSPREE_FORM_ID=

# Rate limit config (used by Apps Script, documented here for visibility)
# RATE_LIMIT_PER_IP=3
# RATE_LIMIT_WINDOW_SEC=60
